{
  "type": "module",
  "name": "carlo-ancebot",
  "version": "1.0.0",
  "description": "A Telegram bot for Bolão Copa 2026",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/bot.js",
    "start:prod": "pm2 start bot.js --name carlo-ancebot --node-args=\"--env-file=.env.production\" --restart-delay=5000 --max-restarts=10",
    "dev": "tsx --watch --env-file=.env.development bot.ts",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^10.4.1",
    "eslint-plugin-perfectionist": "^5.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "grammy": "^1.43.0",
    "prettier": "^3.8.3"
  }
}
